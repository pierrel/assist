# Deployment Configuration
# Copy this file to .deploy.env and fill in your values
# .deploy.env is gitignored and should never be committed

# SSH host alias (define this in ~/.ssh/config)
# Example ~/.ssh/config entry:
#   Host assist-prod
#       HostName your.server.ip
#       User your_username
#       IdentityFile ~/.ssh/id_rsa
DEPLOY_HOST=assist-prod

# Remote deployment path
DEPLOY_PATH=/opt/assist

# Service name (for systemd)
SERVICE_NAME=assist-web

# Environment variables for the service
ASSIST_THREADS_DIR=/var/lib/assist/threads
ASSIST_PORT=8000

# Retention floor for the weekly sweep+VACUUM cron.  The retention
# sweeper keeps the MIN_THREADS most-recently-touched threads and
# hard-deletes everything older from the DB, the filesystem, and
# (in the web process) the in-memory caches.  Without this knob,
# VACUUM just rewrites the same multi-hundred-GB DB every Sunday.
# See docs/2026-05-04-threads-db-layer-0-thread-retention.org.
MIN_THREADS=100

# Production Model Configuration
# These will be set in the systemd service
ASSIST_MODEL_URL=http://your-production-server:8000/v1
ASSIST_MODEL_NAME=your-production-model
ASSIST_API_KEY=your-production-api-key
ASSIST_CONTEXT_LEN=78000
ASSIST_TEST_URL_PATH=/models

# Domains (comma-separated git URLs, first is default)
ASSIST_DOMAINS=user@host:/path/to/repo1.git,user@host:/path/to/repo2.git

# Python version on remote server
PYTHON=python3.14
