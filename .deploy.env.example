# Deployment Configuration
# Copy this file to .deploy.env and fill in your values
# .deploy.env is gitignored and should never be committed

# SSH host alias (define this in ~/.ssh/config)
# Example ~/.ssh/config entry:
#   Host assist-prod
#       HostName your.server.ip
#       User your_username
#       IdentityFile ~/.ssh/id_rsa
DEPLOY_HOST=assist-prod

# Remote deployment path
DEPLOY_PATH=/opt/assist

# Service name (for systemd)
SERVICE_NAME=assist-web

# Environment variables for the service
ASSIST_THREADS_DIR=/var/lib/assist/threads
ASSIST_PORT=8000

# Sandbox egress allowlist.  Comma-separated list of hostnames the
# sandbox is allowed to reach.  Replaces (does not extend) the default
# in dockerfiles/egress-allowlist.conf when set — copy the four
# defaults below if you only mean to add entries.
#
# Default covers: pypi.org + files.pythonhosted.org + pip.pypa.io
# (so `pip install --user` works for the dev-agent) + host.docker.internal
# (so the sandbox can call ASSIST_MODEL_URL on the host gateway).
#
# After changing this, run `make restart` — the proxy is recreated on
# the next sandbox start when the allowlist hash changes.
#ASSIST_SANDBOX_EGRESS_ALLOWLIST=pypi.org,files.pythonhosted.org,pip.pypa.io,host.docker.internal

# Retention floor for the weekly sweep+VACUUM cron.  The retention
# sweeper keeps the MIN_THREADS most-recently-touched threads and
# hard-deletes everything older from the DB, the filesystem, and
# (in the web process) the in-memory caches.  Without this knob,
# VACUUM just rewrites the same multi-hundred-GB DB every Sunday.
# See docs/2026-05-04-threads-db-layer-0-thread-retention.org.
MIN_THREADS=100

# Production Model Configuration
# These will be set in the systemd service
ASSIST_MODEL_URL=http://your-production-server:8000/v1
ASSIST_MODEL_NAME=your-production-model
ASSIST_API_KEY=your-production-api-key
ASSIST_CONTEXT_LEN=78000
ASSIST_TEST_URL_PATH=/models

# Domains (comma-separated git URLs, first is default)
ASSIST_DOMAINS=user@host:/path/to/repo1.git,user@host:/path/to/repo2.git

# Python version on remote server
PYTHON=python3.14

# LLM call wall-clock bounds.  All five are optional with sane
# defaults baked into assist/model_manager.py and assist/agent.py.
# Override here to tune in prod without a code deploy.
#
# CONNECT: how long to wait for the TCP handshake to complete.  10s
# is plenty for a healthy local endpoint.  Was the source of the
# 2026-05-06 incident — a missing per-phase cap let httpcore retry
# connect-tcp for ~3 minutes per attempt against an unreachable
# llama.cpp endpoint.
#ASSIST_LLM_CONNECT_TIMEOUT_S=10.0
#
# READ: max idle time between bytes from the server.  With streaming
# endpoints this is rarely hit, but ChatOpenAI's default is
# non-streaming so this is effectively the cap on time-from-request
# to first response byte.  600s matches the per-thread queue hold
# budget; bump it only if you have very long synthesis calls that
# don't stream tokens.
#ASSIST_LLM_READ_TIMEOUT_S=600.0
#
# WRITE: max time to send the request body.  Tool-eviction payloads
# can run ~100KB; 60s is generous.
#ASSIST_LLM_WRITE_TIMEOUT_S=60.0
#
# POOL: max time to acquire a connection from the httpx pool.  If
# you ever see this fire, something else is wrong; failing fast is
# the right call.
#ASSIST_LLM_POOL_TIMEOUT_S=10.0
#
# MAX_RETRIES: ModelRetryMiddleware retries on transient errors
# (APIConnectionError, InternalServerError, TimeoutError,
# ConnectionError) with exponential backoff.  Default 3 = up to 4
# total attempts per logical model call.  Drop to 1 or 2 if an
# endpoint outage means retrying just spends wall-clock before the
# inevitable failure.
#ASSIST_LLM_MAX_RETRIES=3
