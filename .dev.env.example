# Development Environment Configuration
# Copy this file to .dev.env and fill in your local values
# .dev.env is gitignored and should never be committed

# Local Model Configuration
ASSIST_MODEL_URL=http://localhost:8000/v1
ASSIST_MODEL_NAME=mistralai/Ministral-3-8B-Instruct-2512
ASSIST_API_KEY=sk-local-test-123
ASSIST_CONTEXT_LEN=78000
ASSIST_TEST_URL_PATH=/models

# Domains (comma-separated git URLs, first is default)
ASSIST_DOMAINS=user@localhost:/path/to/repo1.git,user@localhost:/path/to/repo2.git

# Local Data Directory
ASSIST_THREADS_DIR=/tmp/assist_threads

# Port for local development
ASSIST_PORT=8000

# vLLM Remote Service
VLLM_HOST=192.168.1.100
VLLM_USER=youruser
VLLM_PATH=/home/youruser/src/serve/vllm
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEM_UTIL=0.92
VLLM_PORT=8000
VLLM_SERVICE_NAME=vllm-serve
